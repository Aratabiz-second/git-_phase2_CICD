{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "UseGitHubConnection",
      "Effect": "Allow",
      "Action": "codeconnections:UseConnection",
      "Resource": "${connection_arn}"
    },
    {
      "Sid": "StartPipelineBuilds",
      "Effect": "Allow",
      "Action": [
        "codebuild:BatchGetBuilds",
        "codebuild:StartBuild"
      ],
      "Resource": "${codebuild_terraform_project_arn}"
    },
    {
      "Sid": "ListArtifactBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketVersioning",
        "s3:ListBucket"
      ],
      "Resource": "${artifact_bucket_arn}"
    },
    {
      "Sid": "ReadWriteArtifacts",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:PutObject"
      ],
      "Resource": "${artifact_bucket_objects_arn}"
    },
    {
      "Sid": "UseArtifactAndPipelineKeys",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt",
        "kms:DescribeKey",
        "kms:Encrypt",
        "kms:GenerateDataKey"
      ],
      "Resource": [
        "${artifact_kms_key_arn}",
        "${pipeline_kms_key_arn}"
      ],
      "Condition": {
        "StringEquals": {
          "kms:ViaService": [
            "s3.${aws_region}.amazonaws.com",
            "codepipeline.${aws_region}.amazonaws.com"
          ]
        }
      }
    }
  ]
}
