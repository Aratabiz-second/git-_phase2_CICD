{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowRootKeyAdministration",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::${ACCOUNT}:root"
      },
      "Action": "kms:*",
      "Resource": "*"
    },
    {
      "Sid": "AllowKeyUseByPrincipals",
      "Effect": "Allow",
      "Principal": {
        "AWS": ["${KEY_USAGE_PRINCIPAL_ARNS}"]
      },
      "Action": [
        "kms:Decrypt",
        "kms:DescribeKey",
        "kms:Encrypt",
        "kms:GenerateDataKey",
        "kms:GenerateDataKeyWithoutPlaintext",
        "kms:ReEncryptFrom",
        "kms:ReEncryptTo"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "kms:ViaService": ["${VIA_SERVICE_NAMES}"]
        }
      }
    },
    {
      "Sid": "AllowGrantManagementByPrincipals",
      "Effect": "Allow",
      "Principal": {
        "AWS": ["${KEY_USAGE_PRINCIPAL_ARNS}"]
      },
      "Action": [
        "kms:CreateGrant",
        "kms:ListGrants",
        "kms:RevokeGrant"
      ],
      "Resource": "*",
      "Condition": {
        "Bool": {
          "kms:GrantIsForAWSResource": "true"
        }
      }
    },
    {
      "Sid": "AllowCloudWatchLogsKeyUse",
      "Effect": "Allow",
      "Principal": {
        "Service": "logs.${REGION}.amazonaws.com"
      },
      "Action": [
        "kms:Decrypt",
        "kms:DescribeKey",
        "kms:Encrypt",
        "kms:GenerateDataKey",
        "kms:GenerateDataKeyWithoutPlaintext",
        "kms:ReEncryptFrom",
        "kms:ReEncryptTo"
      ],
      "Resource": "*",
      "Condition": {
        "ArnLike": {
          "kms:EncryptionContext:aws:logs:arn": "arn:aws:logs:${REGION}:${ACCOUNT}:log-group:${LOG_GROUP_NAME_PREFIX}*"
        }
      }
    }
  ]
}
